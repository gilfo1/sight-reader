{
  "name": "sight-reader",
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:docs": "playwright test --project=chromium",
    "test:all": "./test_all.sh",
    "type-check": "tsc --noEmit"
  },
  "build": {
    "appId": "com.sight-reader.app",
    "productName": "Sight Reader",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "vexflow": "^5.0.0",
    "webmidi": "^3.1.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@vitest/browser": "^3.2.4",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^26.1.0",
    "typescript": "^6.0.2",
    "vite": "^6.4.2",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4"
  }
}
